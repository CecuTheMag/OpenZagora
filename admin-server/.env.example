# ==========================================
# Open Zagora Admin Server Environment Configuration
# ==========================================

# Server Configuration
NODE_ENV=development
ADMIN_PORT=5001
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_ISSUER=openzagora-admin
JWT_AUDIENCE=openzagora-admin-api

# Admin Client URL (for CORS)
ADMIN_CLIENT_URL=http://localhost:5174

# ==========================================
# ADMIN DATABASE (Authentication & Audit Logs)
# COMPLETELY SEPARATE from main application database
# ==========================================
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_NAME=openzagora_admin
ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=change_this_password_in_production

# Admin Database SSL (Production only)
# ADMIN_DB_SSL_CA=/path/to/ca-certificate.crt

# ==========================================
# MAIN DATABASE (PDF Storage & Application Data)
# This is where PDFs and parsed data are stored
# ==========================================
MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_NAME=openzagora
MAIN_DB_USER=postgres
MAIN_DB_PASSWORD=postgres

# Main Database SSL (Production only)
# MAIN_DB_SSL_CA=/path/to/ca-certificate.crt

# ==========================================
# Security Settings
# ==========================================
# BCRYPT_ROUNDS=12
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Default Admin Credentials (Change in production!)
# Username: admin
# Password: admin123
# These are defined in schema.sql
# ==========================================
