NODE_ENV=development
ADMIN_PORT=5001
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long
JWT_EXPIRES_IN=24h
JWT_ISSUER=openzagora-admin
JWT_AUDIENCE=openzagora-admin-api

ADMIN_CLIENT_URL=http://localhost:5174

# Admin Database
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_NAME=openzagora_admin
ADMIN_DB_USER=admin_user
ADMIN_DB_PASSWORD=admin_pass

# Main Database
MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_NAME=openzagora
MAIN_DB_USER=postgres
MAIN_DB_PASSWORD=postgres